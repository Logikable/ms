# Its range and movement speed are things this game has no notion of, but its
# attack speed is real: +1 stage, flat at every level, so a single point buys
# the whole ~8% DPS. Learned at all is enough.
name: "Archery Mastery"
kind: SKILL_KIND_PASSIVE
job_advancement: JOB_ADVANCEMENT_ARCHER
max_level: 15
base {
  attack_speed: 1
}
